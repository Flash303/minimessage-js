  "description": "Reimplementation of MiniMessage and associated Adventure APIs in TypeScript",
  "main": "dist/minimessage.cjs.js",
  "module": "dist/minimessage.esm.js",
  "browser": "dist/minimessage.umd.js",
  "types": "types/index.d.ts",
  "type": "module",
  "files": [ "dist", "types" ],
  "author": "wasabithumbs",
